# PostgreSQL
POSTGRES_PASSWORD=iptv_gateway_secret

# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=ea-iptv.leyluz.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://ea-iptv.leyluz.com
CORS_ORIGINS=https://ea-iptv.leyluz.com

# Clave Fernet (opcional; si no se define, se deriva de DJANGO_SECRET_KEY)
# Generar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
IPTV_ENCRYPTION_KEY=

# Tiempo de inactividad antes de liberar sesión (minutos)
SESSION_INACTIVITY_MINUTES=5

# URL base del proveedor Xtream (sin barra final)
# Ejemplo: http://mi-proveedor.com:8080
XTREAM_SERVER_URL=

# ---------------------------------------------------------------------------
# Cuentas IPTV del gateway
#
# Cada bloque es una cuenta con NOMBRE FIJO (Luken, Rebe, …) para el gateway.
# El login de la API sigue siendo: luken, rebe, helios, carmen, arturo
#
# Para Xtream Codes (player_api.php, get.php, etc.) se usan SOLO estas dos
# variables — NO el nombre de la cuenta:
#   IPTV_ACCOUNT_<NOMBRE>_USERNAME  → usuario real del proveedor
#   IPTV_ACCOUNT_<NOMBRE>_PASSWORD  → contraseña real del proveedor
# ---------------------------------------------------------------------------

# Cuenta: Luken (nombre interno) | login API: luken
IPTV_ACCOUNT_LUKEN_USERNAME=
IPTV_ACCOUNT_LUKEN_PASSWORD=

# Cuenta: Rebe (nombre interno) | login API: rebe
IPTV_ACCOUNT_REBE_USERNAME=
IPTV_ACCOUNT_REBE_PASSWORD=

# Cuenta: Helios (nombre interno) | login API: helios
IPTV_ACCOUNT_HELIOS_USERNAME=
IPTV_ACCOUNT_HELIOS_PASSWORD=

# Cuenta: Carmen (nombre interno) | login API: carmen
IPTV_ACCOUNT_CARMEN_USERNAME=
IPTV_ACCOUNT_CARMEN_PASSWORD=

# Cuenta: Arturo (nombre interno) | login API: arturo
IPTV_ACCOUNT_ARTURO_USERNAME=
IPTV_ACCOUNT_ARTURO_PASSWORD=

# Usuarios API (login JWT del gateway). Si se omiten, usan la contraseña Xtream de arriba.
IPTV_USER_LUKEN_PASSWORD=
IPTV_USER_REBE_PASSWORD=
IPTV_USER_HELIOS_PASSWORD=
IPTV_USER_CARMEN_PASSWORD=
IPTV_USER_ARTURO_PASSWORD=

# Superusuario Django Admin (opcional)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost
DJANGO_SUPERUSER_PASSWORD=
